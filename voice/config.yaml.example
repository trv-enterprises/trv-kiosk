# Voice Pipeline Configuration (EXAMPLE)
#
# This file is a documentation sample showing all available config
# keys with placeholder values. For deployment via Ansible, the
# template at voice/config.yaml.j2 is rendered with real values from
# inventory.
#
# For local/standalone dev, copy this file to config.yaml and edit
# the placeholders marked with <...> or YOUR_... to point at real
# resources on your network.

wake_word:
  # Model name (built-in or path to custom model)
  # Options: hey_jarvis, alexa, hey_mycroft
  model: "hey_jarvis"
  # Detection sensitivity (0.0 - 1.0) - lower = more sensitive
  sensitivity: 0.2
  # Audio settings
  sample_rate: 16000
  chunk_size: 1280  # ~80ms at 16kHz

whisper:
  # Model size: tiny, base, small, medium, large-v2, large-v3
  model: "base"
  # Device: cuda, cpu
  device: "cpu"
  # Compute type: int8, float16, float32 (int8 for CPU efficiency)
  compute_type: "int8"
  # Language
  language: "en"
  # Beam size (1 = greedy decoding, faster for short commands)
  beam_size: 1
  # Silence detection
  vad_filter: true
  # Max duration of recording after wake word (seconds) - safety net only
  max_recording_duration: 6
  # Bias decoder toward expected vocabulary (reduces mishearings)
  initial_prompt: "timer alarm cancel reset show clock dashboard camera frigate weather forecast alerts notifications minute minutes hour seconds next previous dismiss reviewed close"

vad:
  # WebRTC VAD aggressiveness (0-3, higher = more aggressive filtering)
  aggressiveness: 2
  # Silence duration after speech to trigger stop (ms)
  silence_threshold_ms: 600
  # Max wait for speech to start after wake word (ms)
  pre_speech_timeout_ms: 3000
  # Minimum speech duration to accept (ms) - filters out clicks/pops
  min_speech_ms: 200
  # Audio file to play on wake word detection
  confirmation_sound: "/home/<user>/voice-display/sounds/confirm.wav"

intent:
  # Intent resolution uses local pattern matching (no external API).
  # Supported commands:
  # - show/display/go to + clock/time -> show_clock
  # - show/display/go to + camera/cameras/video/frigate -> show_frigate
  # - show/display/go to + dashboard/dash -> show_dashboard
  # - show/display/go to + weather/forecast -> show_weather
  # - show/display/go to + alerts/notifications -> show_alerts
  # - wake/turn on + screen/display -> wake_screen
  # - set/start timer + duration -> set_timer
  # - reset/restart timer [N] -> reset_timer
  # - cancel/stop/clear timer [N] -> cancel_timer
  # - show/display timers -> show_timer

display:
  # Default view on load. The display has no auto-rotating carousel
  # and stays on this view until a voice command, alert, or timer.
  default_view: "dashboard"
  # WebSocket port for display communication
  websocket_port: 8765
  # WebSocket host (localhost since voice runs on same device)
  websocket_host: "localhost"
  # MQTT broker for receiving alerts (Frigate, weather, sensors)
  mqtt_broker: "YOUR_MQTT_BROKER"
  mqtt_port: 1883
  mqtt_topic: "frigate/reviews"
  # MQTT topic used to publish dashboard voice commands (frigate-alert
  # next/previous/dismiss/etc.). Must match the dashboard's
  # dashboard_command_topic setting.
  dashboard_command_topic: "dashboard/cmd"
  # Alert audio settings
  alert_audio_enabled: true
  alert_audio_file: "/home/<user>/voice-display/sounds/alert.mp3"
  alert_audio_device: "plughw:1,0"  # ALSA output device (check with `aplay -l`)
  # Timer alarm sound (repeats every 15s until dismissed)
  timer_alarm_file: "/home/<user>/voice-display/sounds/alert.mp3"
  # Chime sound played when an alert arrives
  chime_audio_file: "/home/<user>/voice-display/sounds/alert.mp3"

server:
  # Backend API URL (dashboard server)
  url: "http://YOUR_DASHBOARD_SERVER:3001"

audio:
  # Device name substring to search for (case-insensitive, survives USB re-enumeration)
  device_name: "EMEET"
  # Fallback device index if name search fails
  device_index: 11
  # Audio format (48000 for EMEET M0 Plus native, resampled to 16000 for Whisper)
  sample_rate: 48000
  channels: 1
  chunk_size: 4410  # ~100ms at 44100Hz
