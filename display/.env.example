# Voice Display Environment Configuration

# API URL - Points to dashboard server-go
# Default: http://YOUR_DASHBOARD_SERVER:3001
# For local development with local dashboard server: http://localhost:3001
VITE_API_URL=http://YOUR_DASHBOARD_SERVER:3001

# Frigate NVR URL
VITE_FRIGATE_URL=http://YOUR_FRIGATE_HOST:5000

# Dashboard UI host (for iframe embedding)
VITE_DASHBOARD_HOST=http://YOUR_DASHBOARD_HOST
VITE_DASHBOARD_USER_ID=default

# MQTT broker WebSocket URL (for weather data)
VITE_MQTT_WS_URL=ws://YOUR_MQTT_BROKER:9001
